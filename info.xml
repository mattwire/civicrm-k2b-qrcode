<?xml version="1.0"?>
<extension key="k2b-qrcode" type="module">
  <file>k2b_qrcode</file>
  <name>K2B QRCode tokens for bus ticket</name>
  <description>This implements a hook for net.ourpowerbase.qrcodecheckin that generates qrcode tokens to be used for a bus ticket</description>
  <license>AGPL-3.0</license>
  <authors>
    <author>
      <name>MJW</name>
      <email>info@mjwconsult.co.uk</email>
      <role>Maintainer</role>
    </author>
  </authors>
  <urls>
    <url desc="Main Extension Page">https://github.com/mattwire/civicrm-k2b-qrcode</url>
    <url desc="Support">https://mjw.pt/support/k2bqrcode</url>
    <url desc="Licensing">http://www.gnu.org/licenses/agpl-3.0.html</url>
  </urls>
  <releaseDate>2026-04-22</releaseDate>
  <version>1.1.0</version>
  <develStage>stable</develStage>
  <compatibility>
    <ver>6.9</ver>
  </compatibility>
  <classloader>
    <psr0 prefix="CRM_" path="."/>
    <psr4 prefix="Civi\" path="Civi"/>
  </classloader>
  <civix>
    <namespace>CRM/K2bQrcode</namespace>
    <format>25.10.2</format>
  </civix>
  <mixins>
    <mixin>scan-classes@1.0.0</mixin>
  </mixins>
  <requires>
    <ext>net.ourpowerbase.qrcodecheckin</ext>
  </requires>
</extension>
